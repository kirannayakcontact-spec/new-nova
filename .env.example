# Shared runtime
APP_TZ=Asia/Kolkata
HOST=0.0.0.0
WEB_PORT=5000
GATEWAY_PORT=3000

# Firebase Realtime Database
# Prefer the complete JSON endpoint.
FIREBASE_URL=https://your-project-default-rtdb.firebaseio.com/titan_master_data.json

# WhatsApp gateway
RESULT_SCRAPE_ENABLED=1
RESULT_SCRAPE_INTERVAL_MS=5000
RESULT_SCRAPE_CONFIRM_COUNT=2
RESULT_SCRAPE_URLS=https://dpbosse.net/

# KALYAN WhatsApp role routing
# Use WhatsApp group JIDs such as 120363012345678901@g.us.
# Multiple group JIDs may be comma-separated.
ROLE_ROUTER_ENABLED=1
KALYAN_ADMIN_GROUP=
KALYAN_INTEL_GROUP=
KALYAN_RESULT_GROUP=
BOOKIE_LOAD_REPORT_GROUP=

# Flask
FLASK_DEBUG=0

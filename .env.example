# Shared runtime
APP_TZ=Asia/Kolkata
HOST=127.0.0.1
WEB_PORT=5000
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=3000

# Firebase Realtime Database — required
# Base URL and complete .json endpoint are both accepted.
FIREBASE_URL=https://your-project-default-rtdb.firebaseio.com/titan_master_data.json

# Generated automatically by scripts/ensure_runtime_env.py --prepare
ADMIN_PASSWORD=CHANGE_ME_AUTO_GENERATED
FLASK_SECRET_KEY=CHANGE_ME_AUTO_GENERATED
ADMIN_API_TOKEN=CHANGE_ME_AUTO_GENERATED
GATEWAY_API_TOKEN=CHANGE_ME_AUTO_GENERATED

# Security defaults
SESSION_COOKIE_SECURE=0
GATEWAY_ALLOW_LOOPBACK_WITHOUT_TOKEN=1
MAX_REQUEST_BYTES=4194304

# WhatsApp gateway
RESULT_SCRAPE_ENABLED=1
RESULT_SCRAPE_INTERVAL_MS=5000
RESULT_SCRAPE_CONFIRM_COUNT=2
RESULT_SCRAPE_URLS=https://dpbosse.net/

# Flask
FLASK_DEBUG=0

+async function stopWhatsAppSocket(reason = "manual_reset"){
+  try { if(sock && typeof sock.end === "function") sock.end(new Error(reason)); } catch(e) {}
+  try { if(sock && sock.ws && typeof sock.ws.close === "function") sock.ws.close(); } catch(e) {}
+  sock = null;
+  connected = false;
+}
